    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Check all possible approval fields from sendAndWait output\nconst data = $input.item.json;\n\n// Check every possible field that could indicate approval\nlet isApproved = false;\n\nif (data.approved === true || data.approved === 'true') isApproved = true;\nif (data.response === 'Approved') isApproved = true;\nif (data.status === 'approved') isApproved = true;\nif (data.action === 'approve') isApproved = true;\n\n// Pass through all original data plus our flag\nreturn { json: { ...data, _isApproved: isApproved } };",
        "options": {}
      },
